###############################################################################
################################ USER CONFIG ##################################
###############################################################################

# Set powerlevel10k theme
zinit ice depth=1; zinit light romkatv/powerlevel10k

# Options
setopt AUTO_CD
setopt HIST_IGNORE_DUPS
setopt SHARE_HISTORY
setopt CORRECT
unset MAIL
unset MAILCHECK

#Aliases
eval $(thefuck --alias)
alias pods="arch -x86_64 pod install"
alias cat="bat"
alias z="nvim ~/.zshrc;zsh"
alias ls="eza --long --git --header --color-scale --sort name \
--time-style long-iso --group --group-directories-first --inode"
alias lsa="eza --long --all --git --header --color-scale --sort name \
--time-style full-iso --group --group-directories-first --inode -u -U -m \
--changed --extended"
alias l="ls"
alias f="fuck"
alias g="git"
alias dev="cd ~/Developer"
alias bumi="ssh faiz@bumicreative.com"
alias brackets="open . -a Brackets.app"
alias chrome="open . -a Google\ Chrome.app"
alias kaai="cd ~/Developer/projects/kaaikani"
alias dirs="dirs -v -l"
alias stat="stat -x"
alias v="vi ~/.vimrc"
alias gcam="git add -A && git commit -m "
alias cc="claude"
# Environment Variables
export EDITOR=nvim
export SITE=/Library/WebServer/Documents
export SERVER_CONFIG=/private/etc/apache2
export INTERVIEW=~/Developer/Career
export CONFIGS=~/Developer/configs
export BOILERPLATE=https://github.com/anotherfaizkhan/boilerplate
export CDPATH=:$HOME
export FK=/Volumes/myfiles.fastmail.com/fk.io
export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export BAT_THEME="gruvbox-dark"
# Functions
size() {
    du -sh $1
}

cheat() {
    curl cheat.sh/$1
}

# TODO: Figure out passing in custom message
send() {
    echo "Commit message: "
    read msg
    git add -A && git commit -m $msg && git push
}

# Other scripts

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh


. /opt/homebrew/opt/asdf/libexec/asdf.sh

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export PATH="$HOME/.local/bin:$PATH"
export PATH="/Applications/Sublime Text.app/Contents/SharedSupport/bin:$PATH"

# Plugins
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Keep left/right arrows as cursor movement, not history navigation
bindkey '\e[C' forward-char
bindkey '\e[D' backward-char

# Shift+Tab cycles backward through completion menu
bindkey '^[[Z' reverse-menu-complete

# Force emacs keybindings - without this, zsh silently defaults to vi mode
# because $EDITOR=nvim contains "vi", which routes backspace through
# vi-backward-delete-char (extra insert-boundary checks, prone to
# multiple beeps) instead of the plain backward-delete-char
bindkey -e
